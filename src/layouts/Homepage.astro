---
import '../styles/style.scss';
import Head from '../components/globals/Head.astro';
import Header from '../components/globals/Header.astro';
import Footer from '../components/globals/Footer.astro';
import json from '../data/site.json';

const themeClass = json.site.meta.theme;

const {
  pageTitle,
  description,
  image,
  noindex,
  nofollow,
  article,
  frontmatter
} = Astro.props;

const finalPageTitle = pageTitle ?? frontmatter?.title;
const finalDescription = description ?? frontmatter?.description;
const finalImage = image ?? frontmatter?.image;
---

<!doctype html>
<html lang="en" dir="ltr">
	<head>
    <Head
      pageTitle={finalPageTitle}
      description={finalDescription}
      image={finalImage}
      noindex={noindex}
      nofollow={nofollow}
      article={article}
    />
	</head>

	<body {...(themeClass && {class: themeClass})}>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
	</body>

</html>

<style lang="scss" is:global>
  @use '../styles/base/vars.scss' as var;
  @use '../styles/base/breakpoints.scss' as *;

  footer {
    @include bp(tablet) {
      opacity: 0;
      transform: translateY(300px);
      animation: slideInFadeBottom 4s ease-out forwards;
    }
  }

</style>