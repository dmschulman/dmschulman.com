---
import Layout from '../layouts/Homepage.astro';
import IntroBlock from '../components/blocks/IntroBlock.astro'
---

<Layout pageTitle="David M. Schulman, now on the web!">
  <IntroBlock />
</Layout>

<style lang="scss" is:global>
  @use '../styles/base/vars.scss' as var;
  @use '../styles/base/breakpoints.scss' as *;

  .intro-block {
    margin-bottom: 5rem;
  }

  .shelf-listing-block {
    opacity: 0;
    animation: fadeIn 1s ease-out forwards;
    animation-delay: 2.5s;
  }
</style>