---
import { getCollection, getEntries, render } from 'astro:content';
import { marked } from 'marked';

import Layout from '../../layouts/Layout.astro';
import Card from '../../components/elements/Card.astro';
import Spacer from '../../components/elements/Spacer.astro';

const entries = (await getCollection('now'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const entry = entries[0];

if (!entry) {
  throw new Error('No entries available');
}

const { Content } = await render(entry);
const readingHtml = entry.data.readingIntro ? marked.parseInline(entry.data.readingIntro) : null;
const listeningHtml = entry.data.listeningIntro ? marked.parseInline(entry.data.listeningIntro) : null;
const watchingHtml = entry.data.watchingIntro ? marked.parseInline(entry.data.watchingIntro) : null;
const books = await getEntries(entry.data.reading);
const albums = await getEntries(entry.data.listening);
const films = await getEntries(entry.data.watching);

const date = new Date(entry.id + 'T00:00:00');
const lastUpdated = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout 
  pageTitle="Now"
  description="An about page can only tell you so much about a person. To see what I'm involved with and engrossed in right now, check out my Now page."
>
	<p class="intro">An about page can only tell you so much about a person. To see what I'm involved with and engrossed in right now, check out my Now page (inspired by Derek Silver's <a href="https://nownownow.com/">nownownow.com</a> project).</p>
	<p class="intro">Last updated: <i><strong>{lastUpdated}</strong></i>.</p>

	{entry.data.reading && entry.data.reading.length > 0 && (
		<>
			<h2>Reading</h2>
			{readingHtml && <p set:html={readingHtml} />}
			<ul class="cards">
				{books.map(book => (
					<li class="d_press-down">
						<Card cardType="media" layoutClass="column" cardClass="media" {...book.data} />
					</li>
				))}
			</ul>
			<Spacer />
		</>
	)}

	{entry.data.listening && entry.data.listening.length > 0 && (
		<>
			<h2>Listening to</h2>
			{listeningHtml && <p set:html={listeningHtml} />}
			<ul class="cards">
				{albums.map(album => (
					<li class="d_press-down">
						<Card cardType="media" layoutClass="column" cardClass="media" {...album.data} />
					</li>
				))}
			</ul>
			<Spacer />
		</>
	)}

	{entry.data.watching && entry.data.watching.length > 0 && (
		<>
			<h2>Watching</h2>
			{watchingHtml && <p set:html={watchingHtml} />}
			<ul class="cards">
				{films.map(film => (
					<li class="d_press-down">
						<Card cardType="media" layoutClass="column" cardClass="media" {...film.data} />
					</li>
				))}
			</ul>
			<Spacer />
		</>
	)}

	<Content />

	<h2>Living</h2>
	<p><strong>Current location:</strong> Philadelphia, PA 🥨.</p>

</Layout>

<style lang="scss" is:global>
  @use '../../styles/base/vars.scss' as var;
  @use '../../styles/base/breakpoints.scss' as *;

	ul.cards {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		grid-template-rows: 1fr;
		gap: 2rem;
		align-items: flex-start;
		justify-content: flex-start;

		@include bp(tablet) {
			grid-template-columns: repeat(4, 1fr);
		}

		.image {
			img {
				max-width: 260px;
			}
		}
	}
</style>