---
import json from '../../data/site.json';

const ariaLabel = json.site.navigation.mainNav.ariaLabel;
const navItems = json.site.navigation.mainNav.items;
---
<nav class="main" aria-label={ariaLabel}>
  <ul>
    {navItems.map((item) => (
      <li>
        <a href={item.id ? `#${item.id}` : item.href}>{item.title}</a>
      </li>
    ))}
  </ul>
</nav>

<style lang="scss">
  @use '../../styles/base/vars.scss' as var;
  @use '../../styles/base/breakpoints.scss' as *;

  nav.main {
    ul {
      display: flex;
      flex-direction: row;
      justify-content: center;
      flex-wrap: wrap;
      list-style: none;
      margin: 0 auto;
      padding: 0;
      gap: 0 1rem;

      @include bp(desktop) {
        gap: 0 1.5rem;
      }

      li {
        a {
          min-height: 44px;
          display: flex;
          flex-direction: column;
          justify-content: center;
          font-weight: bold;
          font-size: 1rem;

          @include bp(mobile) {
            font-size: 1.5rem;
          }
          
          @include bp(tablet) {
            font-size: 1.25rem;
          }
        }
      }
    }
  }
</style>