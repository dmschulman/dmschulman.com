---
import Logo from '../../components/elements/Logo.astro';
import MainNavigation from '../../components/globals/MainNavigation.astro';

interface Props {
  isH1?: boolean;
}

const { isH1 = false } = Astro.props;
---

<header>
  <Logo
    isH1={isH1}
  />
  <MainNavigation />
</header>

<style lang="scss">
  @use '../../styles/base/vars.scss' as var;
  @use '../../styles/base/breakpoints.scss' as *;

  header {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;

      @include bp(tablet) {
        flex-direction: row;
        justify-content: space-between;
      }
  }
</style>