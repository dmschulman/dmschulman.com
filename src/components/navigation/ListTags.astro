---
function tagToSlug(tag) {
  return tag.toLowerCase().replace(/\s+/g, '-');
}

export interface Props {
  collection: string;
  tags: string[];
  styled?: boolean;
}

const { collection, tags, styled } = Astro.props;
---

<ul class="tag-list">
  {
    tags.map((tag, index) => (
      <li class={styled ? "tag badge" : "tag"}>
        <a href={`/${collection}/tag/${tagToSlug(tag)}`}>{tag}</a>{!styled && index < tags.length - 1 ? ',' : ''}
      </li>
    ))
  }
</ul>

<style lang="scss">
  @use '../../styles/base/vars.scss' as var;
  @use '../../styles/base/breakpoints.scss' as *;

  ul.tag-list {
    list-style: none;
    margin: 0;
    padding: 0;
    font-weight: bold;
    display: inline-block;

    li {
      display: inline-block;
      font-weight: normal;
      text-transform: capitalize;
      color: var.$color-black;
      margin: 0 1rem 1rem 0;

      a {
        font-weight: normal;
      }
    }
  }
</style>