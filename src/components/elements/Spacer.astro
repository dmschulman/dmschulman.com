---
type Size = 'sm' | 'md' | 'lg';
 
interface Props {
  size?: Size;
}
 
const { size = 'sm' } = Astro.props;
---
 
<div class={`spacer ${size}`} role="separator" aria-hidden="true" />
 
<style lang="scss">
  @use '../../styles/base/vars.scss' as var;
  @use '../../styles/base/breakpoints.scss' as *;

  .spacer {
    display: block;
    width: 100%;

    &.sm { height: 0.5rem; 
        @include bp(tablet) {
            height: 1rem;
        }
    }
    &.md { height: 1rem; 
        @include bp(tablet) {
            height: 2rem;
        }
    }
    &.lg { height: 2rem; 
            @include bp(tablet) {
            height: 3rem;
        }
    }
  }
</style>