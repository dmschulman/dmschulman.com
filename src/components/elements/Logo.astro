---
import json from '../../data/site.json';

interface Props {
  isH1?: boolean;
}

const {
  isH1 = false,
} = Astro.props;

const sitename = json.site.meta.sitename;
const tagline = json.site.meta.tagline;
---

<div class="branding">
  <a class="logo" href="/" title={tagline}>
    <svg role="img" width="100" height="100" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
      <title id="logo-title">{sitename} logo</title>
      <circle cx="50" cy="50" r="45" fill="#1DA1F2" class="bg-circle" />
      <text aria-hidden="true" x="57" y="57" text-anchor="middle" dominant-baseline="central" font-family="monospace" font-size="60" font-weight="bold" fill="#444444">D</text>
      <text aria-hidden="true" x="56" y="57" text-anchor="middle" dominant-baseline="central" font-family="monospace" font-size="61" font-weight="bold" fill="#444444">D</text>
      <text aria-hidden="true" x="55" y="55" text-anchor="middle" dominant-baseline="central" font-family="monospace" font-size="62" font-weight="bold" fill="#444444">D</text>
      <text aria-hidden="true" x="54" y="54" text-anchor="middle" dominant-baseline="central" font-family="monospace" font-size="63" font-weight="bold" fill="#444444">D</text>
      <text aria-hidden="true" x="53" y="53" text-anchor="middle" dominant-baseline="central" font-family="monospace" font-size="64" font-weight="bold" fill="#444444">D</text>
      <text aria-hidden="true" x="52" y="52" text-anchor="middle" dominant-baseline="central" font-family="monospace" font-size="65" font-weight="bold" fill="#444444">D</text>
      <text aria-hidden="true" x="51" y="51" text-anchor="middle" dominant-baseline="central" font-family="monospace" font-size="66" font-weight="bold" fill="#444444">D</text>
      <text aria-hidden="true" x="50" y="50" text-anchor="middle" dominant-baseline="central" font-family="monospace" font-size="66" font-weight="bold" fill="#ffffff">D</text>
    </svg>
    {isH1 ? (
      <h1 class="name">{sitename}</h1>
    ) : (
      <span class="name">{sitename}</span>
    )}
  </a>
</div>

<style lang="scss">
  @use '../../styles/base/vars.scss' as var;
  @use '../../styles/base/breakpoints.scss' as *;

  a.logo {
    text-decoration: none;
    font-weight: bold;

    img,
    svg {
      width: 70px;
      height: auto;

      @include bp(tablet) {
        width: 60px;
      }
    }

    h1,
    span {
      font-size: var.$font-size-h5;
      margin: 0;

      @include bp(tablet) {
        margin: 0 0 0 0.5rem;
      }
    }

    svg {
      .bg-circle {
        animation: hueRotate 5s ease-in-out infinite;
      }

      @keyframes hueRotate {
        0%, 100% {
          filter: hue-rotate(0);
        }

        70% {
          filter: hue-rotate(-190deg);
        }
      }
    }
  }
</style>